---
import SkillCard from "../components/SkillCard.astro";
import { technicalSkills, softSkills, approaches } from "../data/skills";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Juan Kuri | Junior Backend Developer"
    description="Software Engineering student specializing in Java, Spring Boot, Express.js and backend development."
>
    <main>
        <div class="container">
            <section id="welcome">
					<img src="/foto_perfil.png" alt="Juan Kuri" id="profile-photo">
					<div>
						<h1>Juan Kuri</h1>
						<p>Junior Developer | B.Eng. in Software Engineering</p>
					</div>
				</section>
				<section id="about-me">
					<h2>About me</h2>
					<p>Software Engineering student with practical experience building backend systems and REST APIs using Java (Spring Boot) and JavaScript (Node.js/Express). Comfortable working with relational databases, version control, and Linux environments. Familiar with frontend technologies (HTML5, CSS3, Vue.js) at a basic level. Currently in my 3rd year at Universidad Veracruzana, Mexico. Looking for junior developer position where I can contribute to real-world projects and grow within a professional engineering team.</p>
				</section>
				<section id="approach">
					<h3>Experience</h3>
					<h2>My approach to work</h2>
					<p>A few principles that guide how I write code and work with a team.</p>
					<div class="cards">
						{
						approaches.map(({ title, description, icon }) => (
							<SkillCard title={title} description={description}>
							<Fragment set:html={icon} />
							</SkillCard>
						))
						}
					</div>
				</section>
				<section id="technical-skills">
					<h2>Technical skills</h2>
					<div class="cards">
						{
							technicalSkills.map(skill => (
								<SkillCard
									title={skill.title}
									description={skill.description}
								/>
							))
						}
					</div>
				</section>
				<section id="soft-skills">
					<h2>Soft skills</h2>
					
					<div class="cards">
						{
							softSkills.map(skill => (
								<SkillCard
									title={skill.title}
									description={skill.description}
								/>
							))
						}
					</div>

				</section>
				<section id="education">
					<h2>Education</h2>
					<h3>B. Eng. in Software Engineering</h3>
					<p>Universidad Veracruzana, Mexico <br> August 2023 - December 2027</p>
				</section>
				<section id="my-roles">
					<h2>My roles</h2>
					<p>Backend and front developer, Web designer, Technical writer.</p>
				</section>
				<section id="languages">
					<h2>Languages</h2>
					<ul>
						<li>Spanish</li>
						<li>English</li>
					</ul>
				</section>
				<section id="contact">
					<h2>Contact</h2>
					<h3>Email</h3>
					<p>juankupa11@gmail.com</p>
					<h3>Location</h3>
					<p>Orizaba, Veracruz, Mexico</p>
				</section>
        </div>
    </main>

</BaseLayout>